{
  "Swagger": {
    "Enabled":     true,
    "RoutePrefix": "swagger"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://app.kknt.vn",
      "https://admin.kknt.vn"
    ],
    "AllowCredentials": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":           "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System":               "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path":                   "Logs/log-.txt",
          "rollingInterval":        "Day",
          "retainedFileCountLimit": 60,
          "fileSizeLimitBytes":     104857600,
          "rollOnFileSizeLimit":    true,
          "shared":                 true,
          "outputTemplate":         "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{ThreadId}] {SourceContext} | {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  }
}
